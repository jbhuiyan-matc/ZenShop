# Database configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zenshop

# JWT configuration
JWT_SECRET=your_secure_secret_key_change_in_production

# Node environment
NODE_ENV=development

# Session Secret (change in production)
SESSION_SECRET=your_session_secret_change_in_production

# Authentik SSO Configuration (OIDC)
AUTHENTIK_CLIENT_ID=your_authentik_client_id
AUTHENTIK_CLIENT_SECRET=your_authentik_client_secret
AUTHENTIK_ISSUER=https://auth.matcsecdesignc.com/application/o/zenshop
AUTHENTIK_CALLBACK_URL=https://matcsecdesignc.com/auth/callback
AUTHENTIK_LOGOUT_URL=https://auth.matcsecdesignc.com/application/o/zenshop/end-session/
